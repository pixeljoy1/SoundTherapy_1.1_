{
  "name": "bridge-orchestrator-login",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Bridge Orchestrator — sign-in surface built on the Shidoka Design System (Kyndryl). Scaffolded for pixel-perfect code↔Figma sync via Code Connect.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4200",
    "typecheck": "tsc -b --noEmit",
    "figma:connect": "figma connect",
    "figma:publish": "figma connect publish"
  },
  "dependencies": {
    "@kyndryl-design-system/shidoka-applications": "latest",
    "@kyndryl-design-system/shidoka-foundation": "latest",
    "@kyndryl-design-system/shidoka-icons": "latest",
    "lit": "^3.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@figma/code-connect": "latest",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
